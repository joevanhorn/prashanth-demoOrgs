# =============================================================================
# SECURITY POLICY FOR AD SERVER ACCESS
# =============================================================================
# Uses the CORRECT security_policy_v2 schema:
#   - type = "default" (REQUIRED — prevents state drift)
#   - principals.user_groups (NOT principals.groups)
#   - resource_type = "server_based_resource"
#   - Password checkout rules BEFORE SSH rules
#   - admin_level_permissions CANNOT coexist with sudo_command_bundles

# resource "oktapam_security_policy_v2" "ad_server_access" {
#   type        = "default"
#   name        = "AD-Server-Access"
#   description = "Access policy for Active Directory domain servers"
#   active      = true
#   principals  = { user_groups = [oktapam_group.ad_admins.id] }
#
#   rules = [
#     # Rule 1: Password checkout (MUST come before SSH rules)
#     {
#       name          = "ad-password-checkout"
#       resource_type = "server_based_resource"
#       resource_selector = {
#         server_based_resource = {
#           selectors = [
#             {
#               server_label = {
#                 account_selector_type = "username"
#                 account_selector      = { usernames = ["Administrator", "root"] }
#                 server_selector = {
#                   labels = { "system.os_type" = "windows" }
#                 }
#               }
#             }
#           ]
#         }
#       }
#       privileges = [
#         { password_checkout_ssh = { password_checkout_ssh = true } }
#       ]
#     },
#     # Rule 2: RDP/SSH access (MUST come after password checkout)
#     {
#       name          = "ad-server-ssh-access"
#       resource_type = "server_based_resource"
#       resource_selector = {
#         server_based_resource = {
#           selectors = [
#             {
#               server_label = {
#                 account_selector_type = "none"
#                 account_selector      = {}
#                 server_selector = {
#                   labels = { "system.os_type" = "windows" }
#                 }
#               }
#             }
#           ]
#         }
#       }
#       privileges = [
#         {
#           principal_account_ssh = {
#             principal_account_ssh  = true
#             admin_level_permissions = true
#             # NOTE: admin_level_permissions = true means full access.
#             # Do NOT also set sudo_command_bundles — they conflict.
#           }
#         }
#       ]
#     }
#   ]
# }

